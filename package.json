{
  "name": "coursebridge",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "deploy": "bash scripts/deploy.sh",
    "deploy:local": "bash scripts/deploy.sh --skip-pull",
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "db:push": "node scripts/apply-migration.mjs",
    "db:migrate:all": "node scripts/db-migrate-all.mjs",
    "db:provision": "bash scripts/db-provision.sh",
    "db:migrate:supabase-to-postgres": "bash scripts/migrate-supabase-to-shared-postgres.sh",
    "db:validate:migration": "bash scripts/validate-shared-postgres-migration.sh",
    "db:inspect": "node scripts/db-inspect.mjs",
    "import:dry-run": "node scripts/import-course-instructors-dry-run.mjs",
    "import:instructors": "node scripts/import-course-instructors.mjs",
    "import:courses": "node scripts/import-courses-and-assignments.mjs",
    "check:rls": "node scripts/check-core-rls.mjs",
    "db:backup": "bash scripts/backup-db.sh",
    "db:backup:prod": "bash scripts/backup-db.sh --prod",
    "seed:dev": "node scripts/seed-dev.mjs",
    "dev:users": "node scripts/ensure-dev-users.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/pg": "^8.15.6",
    "husky": "^9.1.7",
    "turbo": "^2.9.14",
    "typescript": "^5.9.0"
  },
  "packageManager": "npm@11.12.1"
}
