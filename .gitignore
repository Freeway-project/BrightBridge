# dependencies
node_modules/

# build output
.next/
.next-build/
out/
dist/
coverage/
.turbo/

# graphify — AST cache is reproducible; do not commit
graphify-out/cache/

# env
.env
.env.*
!.env.example
!.env.mirror.example

# system
.DS_Store
.vscode/
*.log
*.tsbuildinfo

# local DB dumps (never commit)
backups/

# deploy marker — written by scripts/deploy.sh, watched at runtime for live update detection
apps/web/.deployment-version

# sensitive data
*Educator*
*Heirarchy*
*.csv

# next.js auto-generated types (regenerated on build)
next-env.d.ts

# external reference repo (Azure DevOps CourseBridge) — never commit
azure-reference/
