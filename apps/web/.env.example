
# Local dev: apps/web/.env
# Production: apps/web/.env.prod (used only for deploy / prod operations)
# Vercel: copy these values into Project Settings -> Environment Variables

# Postgres — required in local, preview, and production. App runtime uses
# the pg pool against this connection string.
#
# Supabase (production / Vercel): use the Transaction pooler URL (port 6543)
# from Supabase Dashboard → Project Settings → Database → Connection pooling.
# Format: postgresql://postgres.[ref]:[password]@aws-1-us-west-2.pooler.supabase.com:6543/postgres
#
# Local dev: postgresql://coursebridge_user:localdev@localhost:5433/coursebridge
DATABASE_URL=
# Vercel/serverless: keep pool size low to avoid exhausting Postgres connections.
PG_POOL_MAX=

# Invite links / manual outreach
# NEXT_PUBLIC_SITE_URL is the base domain for instructor magic links, which are
# generated inside the app and exported for manual mail merge (no trailing slash).
# Set this in production/Vercel. If left blank, prod defaults to
# https://coursebridge.cloud.okanagancollege.ca and dev to http://localhost:3000.
NEXT_PUBLIC_SITE_URL=

# Supabase Realtime for batch instructor export open-tracking. Optional for local dev,
# required in deployed environments if you want the admin batch export panel to live-update.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side Supabase access for batch instructor export queries.
SUPABASE_SERVICE_ROLE_KEY=

# Next.js self-hosting — set once at build time in production so Server Action
# references remain consistent across rebuilds/restarts. Generate a 32-byte
# base64 value and keep the real value only in gitignored env/hosting config.
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# Sentry — error tracking. Get these from sentry.io → Settings → Projects → your-project
# NEXT_PUBLIC_SENTRY_DSN is sent to the browser; the others are build-time only.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN is only needed in CI for source map uploads (add to the deploy env).
# SENTRY_AUTH_TOKEN=

# Optional deployment/build version override. On Vercel this can be set from the
# current git commit so the app can surface the deployed version explicitly.
# GIT_COMMIT_SHA=
# NEXT_PUBLIC_GIT_COMMIT_SHA=
# NEXT_PUBLIC_APP_VERSION=

# RapidAPI — Reddit meme API for icebreaker modal. Get free tier key from rapidapi.com
NEXT_PUBLIC_RAPIDAPI_KEY=

# Anthropic — server-side only. Powers the Content Converter (PDF/Word → Brightspace
# HTML) route at /api/content-converter. Never exposed to the browser. Get a key at
# console.anthropic.com → API Keys.
ANTHROPIC_API_KEY=

# Groq — server-side only. Required by /api/mindfresh/refresh.
GROQ_API_KEY=

# ── Chat hub ─────────────────────────────────────────────────────────────────
# Phase 1 — text chat. Set to "true" once the DB migration is applied and the
# backfill script (scripts/backfill-chat-channels.mjs) has run.
NEXT_PUBLIC_CHAT_ENABLED=

# Maintenance / domain migration override. Optional.
# Set to "true" only when you need to force the app into maintenance mode.
NEXT_PUBLIC_FORCE_MAINTENANCE=

# Metrics endpoint protection. Optional; if set, callers must send
# Authorization: Bearer <token> to /api/metrics.
METRICS_BEARER_TOKEN=

# ── Auth ──────────────────────────────────────────────────────────────────────
# SESSION_SECRET signs the HMAC session cookie.
# Generate: openssl rand -base64 32  (keep stable; rotating invalidates all sessions)
SESSION_SECRET=

# ── Auth: dev-only sign-in bypass ────────────────────────────────────────────
# LOCAL DEV ONLY. Both flags must be set AND NODE_ENV must not be "production"
# for the /auth/dev/login route and the on-page dev panel to activate. Leave
# BOTH blank in any deployed environment.
ENABLE_DEV_LOGIN=
NEXT_PUBLIC_ENABLE_DEV_LOGIN=
