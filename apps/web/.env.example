
# Local dev: apps/web/.env
# Production: apps/web/.env.prod (used only for deploy / prod operations)

# Postgres — required in local, preview, and production. App runtime uses
# the pg pool against this connection string.
DATABASE_URL=

# ── Email ────────────────────────────────────────────────────────────────────
# Sends instructor magic-link invites on "Send to Instructor" and logs every
# attempt to the instructor_emails table (admin Emails tab).
#
# Provider selection (EMAIL_PROVIDER):
#   microsoft-graph | resend | noop | auto (default)
# auto picks the first configured of: microsoft-graph → resend → noop.
# noop is a dev fallback that logs the link to the server console without
# sending — leave everything unset for local testing.
EMAIL_PROVIDER=

# Verified sender, e.g. "CourseBridge <reviews@yourdomain.com>". Used by
# Resend and as the default MS_GRAPH_SENDER.
EMAIL_FROM=

# Resend — get a key at resend.com.
RESEND_API_KEY=

# Microsoft Graph (Azure deployment path). Requires an Entra app registration
# with Application permission Mail.Send (admin-consented). MS_GRAPH_SENDER
# must be a real, licensed mailbox in the tenant; defaults to EMAIL_FROM.
MS_GRAPH_TENANT_ID=
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=
MS_GRAPH_SENDER=
# Absolute base URL used to build invite links (no trailing slash), e.g.
# http://localhost:3000 in dev or https://app.yourdomain.com in production.
NEXT_PUBLIC_SITE_URL=

# Next.js self-hosting — set once at build time in production so Server Action
# references remain consistent across rebuilds/restarts. Generate a 32-byte
# base64 value and keep the real value only in gitignored env/hosting config.
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# Sentry — error tracking. Get these from sentry.io → Settings → Projects → your-project
# NEXT_PUBLIC_SENTRY_DSN is sent to the browser; the others are build-time only.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN is only needed in CI for source map uploads (add to the deploy env).
# SENTRY_AUTH_TOKEN=

# RapidAPI — Reddit meme API for icebreaker modal. Get free tier key from rapidapi.com
NEXT_PUBLIC_RAPIDAPI_KEY=

# Anthropic — server-side only. Powers the Content Converter (PDF/Word → Brightspace
# HTML) route at /api/content-converter. Never exposed to the browser. Get a key at
# console.anthropic.com → API Keys.
ANTHROPIC_API_KEY=

# ── Chat hub ─────────────────────────────────────────────────────────────────
# Phase 1 — text chat. Set to "true" once the DB migration is applied and the
# backfill script (scripts/backfill-chat-channels.mjs) has run.
NEXT_PUBLIC_CHAT_ENABLED=

# ── Auth ──────────────────────────────────────────────────────────────────────
# SESSION_SECRET signs the HMAC session cookie.
# Generate: openssl rand -base64 32  (keep stable; rotating invalidates all sessions)
SESSION_SECRET=

# ── Auth: dev-only sign-in bypass ────────────────────────────────────────────
# LOCAL DEV ONLY. Both flags must be set AND NODE_ENV must not be "production"
# for the /auth/dev/login route and the on-page dev panel to activate. Leave
# BOTH blank in any deployed environment.
ENABLE_DEV_LOGIN=
NEXT_PUBLIC_ENABLE_DEV_LOGIN=
