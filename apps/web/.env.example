
# Local dev: apps/web/.env  (project ref e.g. cloned dev)
# Production: apps/web/.env.prod (ref zgqepddmqgtoeczwoetx) — use only for deploy / prod operations

# Supabase — required in local, preview, and production.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Direct database URL — only required for migration scripts, not normal app runtime.
DATABASE_URL=

# Email (Resend) — sends instructor magic-link invites on "Send to Instructor".
# If RESEND_API_KEY is unset, email sending no-ops and the invite link is logged
# to the server console (useful for local testing). Get a key at resend.com.
RESEND_API_KEY=
# Verified sender, e.g. "CourseBridge <reviews@yourdomain.com>".
EMAIL_FROM=
# Absolute base URL used to build invite links (no trailing slash), e.g.
# http://localhost:3000 in dev or https://app.yourdomain.com in production.
NEXT_PUBLIC_SITE_URL=

# Next.js self-hosting — set once at build time in production so Server Action
# references remain consistent across rebuilds/restarts. Generate a 32-byte
# base64 value and keep the real value only in gitignored env/hosting config.
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# PostHog — product analytics. Use the project token from PostHog project settings.
NEXT_PUBLIC_POSTHOG_TOKEN=
# Backward-compatible alias supported by the app.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Optional: used by the Super Admin analytics tab links/embed.
NEXT_PUBLIC_POSTHOG_PROJECT_ID=
NEXT_PUBLIC_POSTHOG_DASHBOARD_URL=

# Sentry — error tracking. Get these from sentry.io → Settings → Projects → your-project
# NEXT_PUBLIC_SENTRY_DSN is sent to the browser; the others are build-time only.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN is only needed in CI for source map uploads (add to the deploy env).
# SENTRY_AUTH_TOKEN=

# RapidAPI — Reddit meme API for icebreaker modal. Get free tier key from rapidapi.com
NEXT_PUBLIC_RAPIDAPI_KEY=

# Anthropic — server-side only. Powers the Content Converter (PDF/Word → Brightspace
# HTML) route at /api/content-converter. Never exposed to the browser. Get a key at
# console.anthropic.com → API Keys.
ANTHROPIC_API_KEY=
