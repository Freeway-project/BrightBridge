
# Supabase — required in local, preview, and production.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Direct database URL — only required for migration scripts, not normal Vercel runtime.
DATABASE_URL=

# Sentry — error tracking. Get these from sentry.io → Settings → Projects → your-project
# NEXT_PUBLIC_SENTRY_DSN is sent to the browser; the others are build-time only.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN is only needed in CI for source map uploads (add to Vercel env vars).
# SENTRY_AUTH_TOKEN=
