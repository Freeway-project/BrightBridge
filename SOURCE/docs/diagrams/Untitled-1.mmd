graph TB
  %% ===== Client =====
  subgraph Client
    OWUI[Open WebUI]
  end

  %% ===== Backend =====
  subgraph Backend["FastAPI Backend (OpenAI-compatible /v1)"]
    ChatAPI[/POST /v1/chat/completions/]
    EmbedsAPI[/POST /v1/embeddings/]
    Personas[Persona Manager]
    Router[Model Router]
    RAG[RAG Orchestrator]
    Ingest[/Ingestion APIs: /ingest/*/]
  end

  %% ===== Data Layer =====
  subgraph Data["Self-hosted Data Layer"]
    Mongo[(MongoDB<br/>users/chats/personas/files)]
    Qdrant[(Qdrant Vector DB)]
    MinIO[(MinIO Object Storage)]
  end

  %% ===== Providers =====
  subgraph Providers["External (swappable)"]
    OpenAI[(OpenAI Chat & Embeddings)]
    Gemini[(Gemini Models)]
  end

  %% ===== Flows =====
  OWUI --> ChatAPI
  ChatAPI --> Personas
  ChatAPI --> RAG
  RAG --> Qdrant
  RAG --> Mongo
  RAG --> MinIO

  Personas --> Router
  Router -->|model = openai:*| OpenAI
  Router -->|model = gemini:*| Gemini

  EmbedsAPI -->|hosted| OpenAI
  EmbedsAPI -->|self-hosted| Qdrant

  %% Ingestion
  OWUI -. file upload .-> Ingest
  Ingest --> MinIO
  Ingest --> Parser[Parser + OCR (PyMuPDF/Tesseract-ara)]
  Parser --> Chunker[Chunker (≈800–1000 tokens)]
  Chunker --> Embedder[Embedder (mE5/BGE-M3/OpenAI)]
  Embedder --> Qdrant

  %% Persistence
  ChatAPI <--> Mongo