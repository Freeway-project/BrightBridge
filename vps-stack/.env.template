# CourseBridge VPS stack — copy to .env and fill in.
# NEVER commit the filled-in .env.

# --- Image / ports ---
COURSEBRIDGE_IMAGE=okanagan/coursebridge:latest
WEB_PORT=3000
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001

# --- Bundled Postgres (self-hosted — Supabase no longer in the loop) ---
POSTGRES_USER=coursebridge_user
POSTGRES_PASSWORD=
POSTGRES_DB=coursebridge

# --- App ---
# No trailing slash. Used for invite links and the session cookie domain.
APP_BASE_URL=
# Generate: openssl rand -base64 32   (keep stable; rotating invalidates all sessions)
SESSION_SECRET=
MIGRATION_BASELINE_ON_EXISTING=false

# --- Email (instructor invite links) ---
# Provider: microsoft-graph | resend | noop | auto (default: noop logs link to console)
EMAIL_PROVIDER=auto
# Verified sender, e.g. "CourseBridge <reviews@yourdomain.com>"
EMAIL_FROM=
# Resend (simpler path — get key at resend.com)
RESEND_API_KEY=
# Microsoft Graph (if using Exchange/M365 — needs Mail.Send app permission in Entra)
MS_GRAPH_TENANT_ID=
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=
MS_GRAPH_SENDER=

# --- Build / runtime secrets ---
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# --- Observability (external SaaS — still optional) ---
NEXT_PUBLIC_POSTHOG_TOKEN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
NEXT_PUBLIC_POSTHOG_PROJECT_ID=
NEXT_PUBLIC_POSTHOG_DASHBOARD_URL=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# --- Self-hosted monitoring (Prometheus + Grafana inside this stack) ---
# Bearer token Prometheus uses to scrape the app's /api/metrics endpoint.
# Must match prometheus/metrics_token. Generate: `openssl rand -hex 32`.
METRICS_BEARER_TOKEN=
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=

# --- Automatic Postgres backup (pg_dump on cron, rotated retention) ---
# SCHEDULE accepts cron syntax (`30 2 * * *`) or shortcuts (`@daily`, `@hourly`).
BACKUP_SCHEDULE=@daily
BACKUP_KEEP_DAYS=14
BACKUP_KEEP_WEEKS=4
BACKUP_KEEP_MONTHS=6

# --- Misc ---
NEXT_PUBLIC_RAPIDAPI_KEY=
GROQ_API_KEY=
NEXT_PUBLIC_FORCE_MAINTENANCE=false
NEXT_PUBLIC_APP_VERSION=
GIT_COMMIT_SHA=
