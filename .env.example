# Repo-root sample. For Next.js and Supabase, use apps/web/.env.example and apps/web/.env.
# The app runs against EITHER stack via env switches — defaults keep the current
# Supabase + Supabase-Auth behavior; set the vars below to move to Postgres + Azure OIDC.

# ── Data provider ────────────────────────────────────────────────────────────
# DB_PROVIDER=supabase (default) | postgres
DB_PROVIDER=
# Required when DB_PROVIDER=postgres (also used by scripts/db-migrate-all.mjs).
DATABASE_URL=
# Optional pg pool size (default 10).
PG_POOL_MAX=
# Set to true for the cutover path: record migrations as applied without executing
# them (used after a pg_dump/pg_restore from Supabase into the target Postgres).
MIGRATION_BASELINE_ON_EXISTING=

# ── Auth provider ────────────────────────────────────────────────────────────
# AUTH_PROVIDER unset = Supabase Auth (default). Set to azure-oidc for Entra SSO.
AUTH_PROVIDER=
# Client-visible mirror (inlined at build time) — drives the "Sign in with
# Microsoft" button on the login page. Set to azure-oidc alongside AUTH_PROVIDER.
NEXT_PUBLIC_AUTH_PROVIDER=
# HMAC key for the signed coursebridge_auth_session cookie (>= 16 chars). Required
# when AUTH_PROVIDER=azure-oidc. Rotating it invalidates all active sessions.
SESSION_SECRET=
# Public base URL used to build OIDC redirects (falls back to the request URL).
APP_BASE_URL=
# Azure Entra application registration:
AZURE_OIDC_TENANT_ID=
AZURE_OIDC_CLIENT_ID=
AZURE_OIDC_CLIENT_SECRET=
AZURE_OIDC_ISSUER=
AZURE_OIDC_AUTHORIZATION_ENDPOINT=
AZURE_OIDC_TOKEN_ENDPOINT=
AZURE_OIDC_JWKS_URI=
AZURE_OIDC_REDIRECT_URI=
AZURE_OIDC_POST_LOGOUT_REDIRECT_URI=
AZURE_OIDC_SCOPES=openid profile email
AZURE_OIDC_ALLOWED_TENANT_ID=

# ── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Local/server only. Never expose this in browser code.
SUPABASE_SERVICE_ROLE_KEY=

# ── Next.js server actions ───────────────────────────────────────────────────
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# ── Analytics / monitoring (optional) ────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_TOKEN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_PROJECT_ID=
NEXT_PUBLIC_POSTHOG_DASHBOARD_URL=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_RAPIDAPI_KEY=

# ── Email provider ───────────────────────────────────────────────────────────
# Selects which provider sends transactional email. Unset / "auto" picks the
# first configured of: microsoft-graph → resend → noop (dev fallback that
# logs to the server console without sending).
# EMAIL_PROVIDER=microsoft-graph | resend | noop | auto
EMAIL_PROVIDER=
# Verified sender used by Resend and as the default MS_GRAPH_SENDER.
# Format: "CourseBridge <reviews@yourdomain.com>".
EMAIL_FROM=
# Resend — used when EMAIL_PROVIDER=resend (or auto + Graph unconfigured).
RESEND_API_KEY=
# Microsoft Graph (Azure path). Requires an Entra app registration with the
# *Application* permission Mail.Send (admin-consented). The sender mailbox
# must be a real, licensed mailbox in the tenant.
MS_GRAPH_TENANT_ID=
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=
# Mailbox the Graph sendMail call targets. Falls back to EMAIL_FROM.
MS_GRAPH_SENDER=

# ── Ops toggles ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_FORCE_MAINTENANCE=
NEXT_PUBLIC_APP_VERSION=
GIT_COMMIT_SHA=

# ── Chat hub ─────────────────────────────────────────────────────────────────
# Phase 1 — text chat. Set to "true" once the DB migration is applied and the
# backfill script (scripts/backfill-chat-channels.mjs) has run.
NEXT_PUBLIC_CHAT_ENABLED=
