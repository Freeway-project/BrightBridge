# ============================================================
# .env.mirror — Dev mirror configuration
#
# This file is used by scripts/mirror-to-dev.sh ONLY.
# It is gitignored — never commit real credentials.
# ============================================================

# The DATABASE_URL for your DEV Supabase project.
# Find it in: Supabase Dashboard → Project Settings → Database → Connection string (URI)
# Make sure to replace [YOUR-PASSWORD] with the actual DB password.
#
DEV_DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-DEV-PROJECT-REF].supabase.co:5432/postgres"

# ────────────────────────────────────────────────────────────
# After mirror, also update apps/web/.env (local dev) so URL + keys
# are all the same dev project ref (production ref is apps/web/.env.prod):
#
# NEXT_PUBLIC_SUPABASE_URL=https://[YOUR-DEV-PROJECT-REF].supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-DEV-PROJECT-REF].supabase.co:5432/postgres
# ────────────────────────────────────────────────────────────
