# ============================================================
# .env.mirror — Dev mirror configuration
#
# This file is used by scripts/mirror-to-dev.sh ONLY.
# It is gitignored — never commit real credentials.
# ============================================================

# The DATABASE_URL for your DEV Supabase project.
# Find it in: Supabase Dashboard → Project Settings → Database → Connection string (URI)
# Use the **direct** `db.*` host (port 5432), not the pooler, so TRUNCATE/auth mirror works.
#
DEV_DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-DEV-PROJECT-REF].supabase.co:5432/postgres"

# Production DB URI for mirror source. Set this when apps/web/.env points at dev — do not read
# prod from the same file as local app config.
#
# PROD_DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[YOUR-PROD-PROJECT-REF].supabase.co:5432/postgres"

# Full clone (default 1): copy auth.users + auth.identities so prod accounts can sign in on dev
# and public.profiles FKs stay valid. Set to 0 only if you manage auth separately.
#
# MIRROR_INCLUDE_AUTH=1

# Comma-separated extra app schemas besides public (default: monitoring). Use none for public-only.
#
# MIRROR_EXTRA_SCHEMAS=monitoring

# ────────────────────────────────────────────────────────────
# After mirror, also update apps/web/.env (local dev) so URL + keys
# are all the same dev project ref (production ref is apps/web/.env.prod):
#
# NEXT_PUBLIC_SUPABASE_URL=https://[YOUR-DEV-PROJECT-REF].supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-DEV-PROJECT-REF].supabase.co:5432/postgres
# ────────────────────────────────────────────────────────────
